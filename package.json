{
  "name": "orbit-overlay",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "build": {
    "appId": "com.orbit.overlay",
    "productName": "Orbit",
    "win": {
      "target": "portable",
      "icon": "build/icon.png"
    },
    "files": [
      "src/**/*",
      "package.json",
      "build/icon.png"
    ],
    "directories": {
      "output": "dist-app"
    }
  }
}
