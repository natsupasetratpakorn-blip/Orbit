# Copy to .env and fill in. The gateway reads these at startup.
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
PORT=8080
# Where to persist per-key daily usage (defaults to ./usage.json).
USAGE_FILE=/opt/orbit/usage.json

# ─── Vertex auth ─────────────────────────────────────────────────────────────
# The gateway authenticates to Vertex with Application Default Credentials, so
# you do NOT need a service-account key. Pick ONE of these on the box:
#
#   (a) gcloud login (no key file — works even if SA keys are org-disabled):
#         gcloud auth application-default login
#       This writes ~/.config/gcloud/application_default_credentials.json, which
#       GoogleAuth finds automatically. Leave GOOGLE_APPLICATION_CREDENTIALS unset.
#
#   (b) a service-account JSON key, if you have one — point at it explicitly:
#         GOOGLE_APPLICATION_CREDENTIALS=/opt/orbit/orbit-sa-key.json
